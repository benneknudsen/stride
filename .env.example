# Database
DATABASE_URL=

# Auth (NextAuth v5)
AUTH_SECRET=
# Canonical origin of the deployment, e.g. https://stride.run (origin only, no
# trailing path). Vercel sets this automatically; set it explicitly when
# self-hosting so Auth.js builds callback + magic-link URLs from it rather than
# the request's Host header (issue #143). `trustHost: true` (auth.config.ts)
# handles host trust; this pins the URL so a spoofed Host cannot rewrite links.
AUTH_URL=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Garmin Connect OAuth 2.0 PKCE (issue #35)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
# The callback registered in Garmin's developer portal. NextAuth owns this path,
# so it must be exactly <AUTH_URL>/api/auth/callback/garmin — the app does not
# read this var, it records the value the portal has to match.
GARMIN_REDIRECT_URI=
# Shared secret for the push webhook. Garmin does not sign its payloads and its
# portal only accepts a URL, so the registered endpoint URL carries the credential:
#   https://<host>/api/garmin/webhook?token=<GARMIN_WEBHOOK_SECRET>
# Any other caller should send it as the X-Garmin-Webhook-Token header instead —
# query strings leak into access logs. Unset = every webhook POST is rejected.
GARMIN_WEBHOOK_SECRET=
# Hosts a ping notification's callbackURL may point at. The webhook attaches the
# athlete's OAuth bearer token to that fetch, so the destination is allowlisted by
# exact hostname to stop a forged payload exfiltrating the token (SSRF).
# GARMIN_CALLBACK_HOSTS=apis.garmin.com,healthapi.garmin.com
# Optional endpoint overrides — defaults are Garmin's production hosts. Set these
# only if your partner app is provisioned against different ones.
# GARMIN_AUTHORIZATION_URL=https://connect.garmin.com/oauth2Confirm
# GARMIN_TOKEN_URL=https://diauth.garmin.com/di-oauth2-service/oauth/token
# GARMIN_API_BASE=https://apis.garmin.com/wellness-api/rest
# GARMIN_SCOPE=activity:read health:read

# Strava OAuth (kræver Strava-abonnement)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_VERIFY_TOKEN=

# Encryption (32-byte hex key for AES-256-GCM)
ENCRYPTION_KEY=

# Rate limiting — Upstash Redis (Vercel Marketplace sets both automatically).
# Unset = the limiter falls back to a process-local Map, which is fine locally
# but on Vercel means every instance keeps its own counters (issue #88).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI Provider — OpenRouter.
# Set OPENROUTER_API_KEY to enable the AI coach. Without it the app serves
# deterministic scripted replies (the public demo works with no key).
# AI_PRIMARY/AI_FALLBACK are OpenRouter model ids, e.g.
# "deepseek/deepseek-r1-distill-qwen-14b" or "google/gemini-2.0-flash-001".
OPENROUTER_API_KEY=
AI_PRIMARY=
AI_FALLBACK=

# Error observability — Sentry (issue #178).
# Unset = Sentry.init is a no-op and captureError just logs to console; the app
# runs fine without it. SENTRY_DSN is server/edge-side; the browser needs the
# NEXT_PUBLIC_ copy (same DSN value) since server-only vars aren't exposed to it.
# SENTRY_ORG/PROJECT/AUTH_TOKEN are build-time only, for source-map upload.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
