# Database
DATABASE_URL=

# Auth (NextAuth v5)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Garmin Connect OAuth
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Strava OAuth (kræver Strava-abonnement)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_VERIFY_TOKEN=

# Encryption (32-byte hex key for AES-256-GCM)
ENCRYPTION_KEY=

# AI Provider — routed through the Vercel AI Gateway.
# Leave AI_GATEWAY_API_KEY unset to serve the deterministic heuristic analysis
# (the public demo works with no key). AI_PRIMARY/AI_FALLBACK are gateway model
# ids, e.g. "anthropic/claude-haiku-4-5" and "openai/gpt-4o-mini".
AI_GATEWAY_API_KEY=
AI_PRIMARY=
AI_FALLBACK=
